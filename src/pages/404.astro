---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Groundwork | Not found">
  <main style="min-height:100vh; display:grid; place-items:center; text-align:center; padding:1rem;">
    <section>
      <p style="font-family:var(--font-display); font-size:6rem; margin:0; color:var(--color-accent); line-height:1;">404</p>
      <p style="max-width:36ch; color:var(--color-text-muted); margin:0.8rem auto 1rem;">
        This page doesn't exist. Check the URL or head back to your dashboard.
      </p>
      <a class="btn btn-ghost" href="/">Back home</a>
    </section>
  </main>
</BaseLayout>
